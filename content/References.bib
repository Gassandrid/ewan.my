@article{arnstenEffects5HT3Receptor1997,
  title = {The Effects of 5-{{HT3}} Receptor Antagonists on Cognitive Performance in Aged Monkeys},
  author = {Arnsten, A. F. and Lin, C. H. and Van Dyck, C. H. and Stanhope, K. J.},
  year = 1997,
  journal = {Neurobiology of Aging},
  volume = {18},
  number = {1},
  pages = {21--28},
  issn = {0197-4580},
  doi = {10.1016/s0197-4580(96)00162-5},
  abstract = {The serotonin 5-HT3 receptor antagonists ondansetron and SEC-579 were tested over a wide dose range (0.000001-0.5 mg/kg, PO) for cognitive-enhancing effects in aged rhesus monkeys. Animals were tested on the following cognitive and motor tasks: 1) acquisition of a visual object discrimination; 2) reversal of a visual object discrimination; 3) the delayed response task, a spatial working memory task; and 4) a fine motor task. This study found enhanced acquisition of a visual object discrimination following very low doses (0.000001-0.00001 mg/kg, PO) of either 5-HT3 receptor antagonist. This finding replicates a previous study in marmosets. However, unlike the marmoset research, no reliable improvement was found on the reversal condition. Similarly, no improvement was observed on the delayed response or fine motor tasks. No side effects were observed at any dose, consistent with reports in both animals and humans. These results suggest that 5-HT3 receptor antagonists may be helpful in treating a subset of cognitive functions.},
  langid = {english},
  pmid = {8983029},
  keywords = {Aging,Animals,Cognition,Conditioning Operant,Discrimination Learning,Discrimination Psychological,Female,Macaca mulatta,Motivation,Motor Cortex,Ondansetron,Psychomotor Performance,Quinolones,Reversal Learning,Serotonin Antagonists,Visual Perception}
}

