views:
  - type: cards
    name: Table
    filters:
      and:
        - class == ["medication"]
        - category.contains("cognitive")
    order:
      - type
      - targets
      - pathways
      - processes
      - brain-regions
      - benefits
      - stacks-well-with
      - file.name
    sort:
      - property: image
        direction: ASC
    image: note.image
